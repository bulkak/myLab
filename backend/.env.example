# Скопируйте в .env на сервере: cp .env.example .env
# Секреты провайдеров задайте в .env.local или через переменные окружения контейнера.

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_this_secret_key_for_production_environment
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/mylab?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=amqp://guest:guest@rabbitmq:5672/%2f/messages
MESSENGER_TRANSPORT_OCR_DSN=amqp://guest:guest@rabbitmq:5672/%2f/ocr
###< symfony/messenger ###

###> redis ###
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
###< redis ###

###> gigachat ###
GIGACHAT_AUTH_KEY=
GIGACHAT_MODEL=GigaChat-Max
###< gigachat ###

###> openai ###
OPENAI_API_KEY=
OPENAI_API_URL=https://api.apiyi.com/v1/chat/completions
###< openai ###

###> yandex_cloud ###
YANDEX_CLOUD_API_KEY=
YANDEX_CLOUD_FOLDER=
###< yandex_cloud ###

###> app ###
UPLOAD_DIR=/var/www/uploads
MAX_UPLOAD_SIZE=52428800
TOTP_ISSUER=myLab
###< app ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

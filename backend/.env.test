APP_ENV=test
APP_DEBUG=1
KERNEL_CLASS=App\Kernel

###> doctrine/doctrine-bundle ###
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/mylab_test?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=amqp://guest:guest@rabbitmq:5672/%2f/messages_test
MESSENGER_TRANSPORT_OCR_DSN=amqp://guest:guest@rabbitmq:5672/%2f/ocr_test
###< symfony/messenger ###

###> redis ###
REDIS_URL=redis://redis:6379/1
###< redis ###

###> gigachat ###
GIGACHAT_AUTH_KEY=test_key
GIGACHAT_MODEL=GigaChat-Pro
###< gigachat ###

###> app ###
UPLOAD_DIR=/var/www/uploads_test
MAX_UPLOAD_SIZE=52428800
TOTP_ISSUER=myLab
###< app ###

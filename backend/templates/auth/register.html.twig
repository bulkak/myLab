{% extends 'base.html.twig' %}

{% block title %}Регистрация - myLab{% endblock %}

{% block body %}
<div class="card" style="max-width: 400px; margin: 0 auto;">
    <h2 style="margin-bottom: 20px; text-align: center;">Регистрация</h2>
    
    {% if error is defined and error %}
        <div class="error">{{ error }}</div>
    {% endif %}
    
    <form method="POST" action="{{ path('auth_register') }}">
        <div class="form-group">
            <label for="username">Придумайте логин</label>
            <input 
                type="text" 
                id="username" 
                name="username" 
                value="{{ username }}"
                placeholder="Например: ivan_petrov"
                required
                minlength="3"
                maxlength="50"
                autocomplete="username"
            >
            <small style="color: #666; display: block; margin-top: 5px;">
                Только буквы, цифры, дефис и подчеркивание
            </small>
        </div>
        
        <button type="submit" style="width: 100%;">Продолжить</button>
    </form>
    
    <p style="text-align: center; margin-top: 20px;">
        Уже есть аккаунт? <a href="{{ path('auth_login') }}">Войти</a>
    </p>
</div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Вход - myLab{% endblock %}

{% block body %}
<div class="card" style="max-width: 400px; margin: 0 auto;">
    <h2 style="margin-bottom: 20px; text-align: center;">Вход в систему</h2>
    
    {% if error is defined and error %}
        <div class="error">{{ error }}</div>
    {% endif %}
    
    <form method="POST" action="{{ path('auth_login') }}">
        <div class="form-group">
            <label for="username">Логин</label>
            <input 
                type="text" 
                id="username" 
                name="username" 
                value="{{ username }}"
                placeholder="Ваш логин"
                required
                autocomplete="username"
            >
        </div>
        
        <div class="form-group">
            <label for="code">Код из Google Authenticator</label>
            <input 
                type="text" 
                id="code" 
                name="code" 
                placeholder="123456"
                required
                maxlength="6"
                pattern="\d{6}"
                inputmode="numeric"
                autocomplete="one-time-code"
                style="font-size: 24px; text-align: center; letter-spacing: 8px;"
            >
        </div>
        
        <button type="submit" style="width: 100%;">Войти</button>
    </form>
    
    <p style="text-align: center; margin-top: 20px;">
        Нет аккаунта? <a href="{{ path('auth_register') }}">Зарегистрироваться</a>
    </p>
</div>
{% endblock %}

# Copy this file on VPS as /opt/mylab/.env.vps and fill real values.
# This file is safe to commit because it contains placeholders only.

# Внешний порт nginx на хосте (80 — сайт без :порт в URL; для другого порта, например 8090, смените здесь)
APP_HTTP_PORT=80
APP_SECRET=change_me_to_long_random_secret
DEFAULT_URI=http://your-domain.example
TOTP_ISSUER=myLab
MAX_UPLOAD_SIZE=52428800

# Optional overrides if you need non-default credentials/hosts.
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/mylab?serverVersion=16&charset=utf8
# REDIS_URL=redis://redis:6379
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@rabbitmq:5672/%2f/messages
# MESSENGER_TRANSPORT_OCR_DSN=amqp://guest:guest@rabbitmq:5672/%2f/ocr

# OCR providers
GIGACHAT_AUTH_KEY=replace_me
GIGACHAT_MODEL=GigaChat-Max
OPENAI_API_KEY=replace_me
OPENAI_API_URL=https://api.apiyi.com/v1/chat/completions
YANDEX_CLOUD_API_KEY=replace_me
YANDEX_CLOUD_FOLDER=replace_me

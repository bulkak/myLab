# Скопируйте на VPS как `.env.vps` в корне репозитория и замените значения на свои.
# Запуск: docker compose --env-file .env.vps -f docker-compose.yml -f docker-compose.prod.yml up -d
#
# ВАЖНО про PostgreSQL:
# - POSTGRES_USER / POSTGRES_PASSWORD задаются при ПЕРВОЙ инициализации тома.
# - Если том уже был с пользователем `postgres`, смена на `deploy` без нового тома не сработает:
#   либо оставьте старые креды, либо создайте роль вручную, либо новый volume (данные пропадут).
#
# Пароли ниже — вымышленные. Для POSTGRES_PASSWORD избегайте символов @ : / ? # & (ломают URL в compose).
# DATABASE_URL в этом файле не нужен: docker-compose собирает её из POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB.

# --- Symfony / HTTP ---
APP_HTTP_PORT=80
APP_SECRET=7f3c9e2a1b8d4f605e7a9c2b4d8f1037e6a5c9d2b8f4e1a0c7d3b9f5e2a8c6d
DEFAULT_URI=http://mylab1.example.ru
TOTP_ISSUER=myLab
MAX_UPLOAD_SIZE=52428800

# --- PostgreSQL (и образ, и app/ocr-worker получают одну и ту же строку подключения из этих трёх переменных) ---
POSTGRES_USER=deploy
POSTGRES_PASSWORD=PgDeploy_xK9mN2wQ7vL4hJ8rT5
POSTGRES_DB=mylab

# --- Redis (официальный образ без ACL по умолчанию — только URL; «пользователь deploy» к Redis не применяется) ---
REDIS_URL=redis://redis:6379

# --- RabbitMQ (тот же логин deploy, что и для БД — по желанию; пароль свой) ---
RABBITMQ_DEFAULT_USER=deploy
RABBITMQ_DEFAULT_PASS=AmqDeploy_yP3nM8kQ1wR6tH9sV2
MESSENGER_TRANSPORT_DSN=amqp://deploy:AmqDeploy_yP3nM8kQ1wR6tH9sV2@rabbitmq:5672/%2f/messages
MESSENGER_TRANSPORT_OCR_DSN=amqp://deploy:AmqDeploy_yP3nM8kQ1wR6tH9sV2@rabbitmq:5672/%2f/ocr

# --- OCR (подставьте реальные ключи) ---
GIGACHAT_AUTH_KEY=replace_me
GIGACHAT_MODEL=GigaChat-Max
OPENAI_API_KEY=replace_me
OPENAI_API_URL=https://api.apiyi.com/v1/chat/completions
YANDEX_CLOUD_API_KEY=replace_me
YANDEX_CLOUD_FOLDER=replace_me
